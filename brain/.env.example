# Telegram Configuration
TELEGRAM_TOKEN=your_telegram_bot_token

# WordPress Gateway Configuration
# Use your LocalWP Live Link URL during development
WP_URL=https://your-site.locl.lt/wp-json/clawwp/v1
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_24_char_app_password

# AI Provider Configuration
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key

# Render Port (Set automatically by Render, but useful for local testing)
PORT=8000
